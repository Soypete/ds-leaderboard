# ── Supabase ──────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY, never expose to the browser. Used by the
# ingest API to insert pending runs past RLS. Keep out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Ingest auth ───────────────────────────────────────────────────────────────
# Shared secret the GitHub Action presents to POST /api/ingest. Generate a long
# random string; set the same value as a secret in the submissions repo.
INGEST_SHARED_SECRET=change-me-to-a-long-random-string

# ── Media storage (Supabase Storage, S3-compatible) ──────────────────────────
# Bucket names. The screenshot bucket is public-read; uploads go through
# presigned URLs minted server-side. CORS for the bucket is set in Supabase
# dashboard (Storage → bucket → CORS) to allow PUT from the site origin.
SUPABASE_MEDIA_BUCKET=ds-media

# ── Moderation ────────────────────────────────────────────────────────────────
# Comma-separated GitHub handles (lowercased) granted global moderator powers
# until guild-scoped roles land.
MODERATOR_HANDLES=captainnobody1
