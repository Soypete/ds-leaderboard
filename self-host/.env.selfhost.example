# Self-host environment — copy to self-host/.env and fill in.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=leaderboard

# ── MinIO (S3-compatible media storage) ───────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-too
MEDIA_BUCKET=ds-media

# ── App ───────────────────────────────────────────────────────────────────────
# Shared secret for the ingest + moderate + media endpoints (same value the
# submissions-repo GitHub Action presents).
INGEST_SHARED_SECRET=a-long-random-string
# Comma-separated GitHub handles (lowercased) with moderator powers.
MODERATOR_HANDLES=
